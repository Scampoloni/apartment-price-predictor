# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data — never commit raw data to version control
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Trained model artifacts — committed so Hugging Face Spaces can serve the app.
# models/*.joblib  ← intentionally NOT ignored
# models/*.json    ← intentionally NOT ignored
models/*.pkl
!models/.gitkeep

# Results
results/figures/*
results/tables/*
!results/figures/.gitkeep
!results/tables/.gitkeep

# Environment variables
.env
*.env

# OS
.DS_Store
Thumbs.db
